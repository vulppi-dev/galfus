{
  "name": "@vulfram/engine",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vulppi-dev/vulfram.git",
    "directory": "packages/engine"
  },
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "default": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./core": {
      "default": "./src/core.ts",
      "import": "./src/core.ts",
      "types": "./src/core.ts"
    },
    "./window": {
      "default": "./src/window.ts",
      "import": "./src/window.ts",
      "types": "./src/window.ts"
    },
    "./mount": {
      "default": "./src/mount.ts",
      "import": "./src/mount.ts",
      "types": "./src/mount.ts"
    },
    "./world3d": {
      "default": "./src/world3d.ts",
      "import": "./src/world3d.ts",
      "types": "./src/world3d.ts"
    },
    "./world-ui": {
      "default": "./src/world-ui.ts",
      "import": "./src/world-ui.ts",
      "types": "./src/world-ui.ts"
    },
    "./ecs": {
      "default": "./src/ecs.ts",
      "import": "./src/ecs.ts",
      "types": "./src/ecs.ts"
    },
    "./types": {
      "default": "./src/types/index.ts",
      "import": "./src/types/index.ts",
      "types": "./src/types/index.ts"
    },
    "./helpers": {
      "default": "./src/helpers/index.ts",
      "import": "./src/helpers/index.ts",
      "types": "./src/helpers/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vulfram/transport-types": "^0.3.0",
    "gl-matrix": "^3.4.4",
    "msgpackr": "^1.11.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "glob": "^13.0.6"
  }
}
