{
  "name": "vulfram-monorepo",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vulppi-dev/vulfram.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "check": "bun scripts/check.ts",
    "lint": "bun scripts/lint.ts",
    "build:local-bindings": "bun scripts/build-local-bindings.ts",
    "artifacts": "bun scripts/artifacts.ts",
    "version": "bun scripts/set-version.ts",
    "release-meta": "bun scripts/release-meta.ts",
    "core-version": "bun scripts/core-version.ts",
    "demo": "bun run --cwd apps/demos demo",
    "format": "prettier --write \"scripts/**/*.ts\" \"packages/**/*.ts\" \"apps/**/*.ts\""
  },
  "devDependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@types/bun": "^1.3.10",
    "commander": "^14.0.3",
    "prettier": "^3.8.1"
  }
}
